# ============================================================
#  .env – Deine geheimen Zugangsdaten
#  DIESE DATEI NIEMALS in Git hochladen!
#  Auf Railway als Environment Variables eintragen
# ============================================================

# ── Airalo Partner API ────────────────────────────────────
AIRALO_CLIENT_ID=deine_airalo_client_id
AIRALO_CLIENT_SECRET=dein_airalo_client_secret

# ── Shopify ───────────────────────────────────────────────
# Den Webhook Secret findest du in:
# Shopify Admin → Settings → Notifications → Webhooks
SHOPIFY_WEBHOOK_SECRET=dein_shopify_webhook_secret

# ── E-Mail (SMTP) ─────────────────────────────────────────
# Beispiel für Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=deine@gmail.com
SMTP_PASS=dein_app_passwort

# Beispiel für Strato/IONOS:
# SMTP_HOST=smtp.strato.de
# SMTP_PORT=587
# SMTP_USER=deine@domain.de
# SMTP_PASS=dein_passwort

# ── Shop Info ─────────────────────────────────────────────
SHOP_NAME=Dein eSIM Shop
SUPPORT_EMAIL=support@deinshop.de

# ── Dashboard API Key ─────────────────────────────────────
# Frei wählbares Passwort für dein Dashboard
# Generiere einen sicheren Key z.B.: openssl rand -hex 32
DASHBOARD_API_KEY=ersetze_mit_langem_zufaelligen_string

# ── Server Port (Railway setzt das automatisch) ───────────
PORT=3000
